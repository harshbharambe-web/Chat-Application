<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>ChatterBox — All Chats</title>
  <link rel="stylesheet" href="/style.css">
</head>
<body>

<div class="page-wrapper">

  <!-- HEADER -->
  <header class="site-header">
    <div class="logo">
      <div class="logo-icon">💬</div>
      <span class="logo-text">Chatter<span>Box</span></span>
    </div>
    <div class="header-actions">
      <a href="/" class="btn btn-ghost">Home</a>
      <a href="/chats/new" class="btn btn-primary">+ New Chat</a>
    </div>
  </header>

  <!-- SECTION HEADER -->
  <div class="section-header">
    <h1 class="section-title">All Messages</h1>
    <span class="section-count"><%= chats.length %> chat<%= chats.length !== 1 ? 's' : '' %></span>
  </div>

  <!-- CHAT LIST -->
  <% if (chats.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">📭</div>
      <h2 class="empty-title">No messages yet</h2>
      <p class="empty-sub">Be the first to start a conversation.</p>
      <a href="/chats/new" class="btn btn-primary">Start a Chat</a>
    </div>
  <% } else { %>
    <div class="chat-list">

      <% for(let c of chats) { %>
        <%
          /* 
           * "Sent by you" logic: we treat 'vir' as the current user. 
           * Replace 'vir' below with your own username or a session-based variable.
           * For now we'll mark cards visually — edit/delete only show on sent cards.
           */
          const CURRENT_USER = 'vir';
          const isSent = c.from.toLowerCase() === CURRENT_USER.toLowerCase();

          /* Format timestamps */
          function formatTime(date) {
            if (!date) return '—';
            const d = new Date(date);
            return d.toLocaleString('en-IN', {
              day: '2-digit', month: 'short', year: 'numeric',
              hour: '2-digit', minute: '2-digit', hour12: true
            });
          }

          const createdAt  = formatTime(c.createAt);
          const updatedAt  = c.updatedAt ? formatTime(c.updatedAt) : null;
          const wasEdited  = updatedAt && updatedAt !== createdAt;
          const initials   = c.from.charAt(0).toUpperCase();
        %>

        <div class="chat-card <%= isSent ? 'sent' : 'received' %>">

          <!-- Card Header -->
          <div class="chat-card-header">
            <div class="avatar <%= isSent ? 'sent-av' : 'recv-av' %>"><%= initials %></div>
            <div class="chat-meta">
              <div class="chat-from">
                <%= c.from %>
                <% if (isSent) { %><span class="you-badge">You</span><% } %>
              </div>
              <div class="chat-to">→ <strong><%= c.to %></strong></div>
            </div>
            <div class="chat-timestamp">
              <span class="time-label">Sent</span>
              <%= createdAt %>
            </div>
          </div>

          <!-- Message Bubble -->
          <div class="chat-bubble"><%= c.msg %></div>

          <!-- Card Footer -->
          <div class="chat-card-footer">

            <!-- Updated time -->
            <div class="chat-updated">
              <% if (wasEdited) { %>
                <span class="update-dot"></span>Edited · <%= updatedAt %>
              <% } else { %>
                &nbsp;
              <% } %>
            </div>

            <!-- Actions (only for sent chats) -->
            <% if (isSent) { %>
              <div class="chat-actions">
                <form method="GET" action="/chats/<%= c._id %>/edit">
                  <button class="btn btn-edit" type="submit">✏️ Edit</button>
                </form>
                <button class="btn btn-danger" onclick="openDeleteModal('<%= c._id %>')">🗑 Delete</button>
              </div>
            <% } %>
          </div>

        </div>
      <% } %>

    </div>
  <% } %>

</div>

<!-- DELETE CONFIRM MODAL -->
<div class="delete-modal-overlay" id="deleteModal">
  <div class="delete-modal">
    <div class="delete-modal-icon">⚠️</div>
    <h2 class="delete-modal-title">Delete Message?</h2>
    <p class="delete-modal-sub">This action cannot be undone. The message will be permanently removed.</p>
    <div class="delete-modal-actions">
      <button class="btn btn-ghost" onclick="closeDeleteModal()">Cancel</button>
      <form id="deleteForm" method="POST" action="">
        <input type="hidden" name="_method" value="DELETE">
        <button class="btn btn-danger" type="submit" style="padding:9px 18px;font-size:0.85rem;">Yes, Delete</button>
      </form>
    </div>
  </div>
</div>

<!-- TOAST -->
<div class="toast" id="toast">✅ Chat deleted successfully!</div>

<script>
  function openDeleteModal(id) {
    document.getElementById('deleteForm').action = '/chats/' + id;
    document.getElementById('deleteModal').classList.add('active');
  }
  function closeDeleteModal() {
    document.getElementById('deleteModal').classList.remove('active');
  }
  // Close on overlay click
  document.getElementById('deleteModal').addEventListener('click', function(e) {
    if (e.target === this) closeDeleteModal();
  });

  // Toast on page load if ?deleted=1
  const params = new URLSearchParams(window.location.search);
  if (params.get('deleted') === '1') {
    const toast = document.getElementById('toast');
    toast.innerText = '🗑 Message deleted.';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3200);
    history.replaceState({}, '', '/chats');
  }
  if (params.get('saved') === '1') {
    const toast = document.getElementById('toast');
    toast.innerText = '✅ Message updated!';
    toast.style.borderLeftColor = 'var(--success)';
    toast.classList.add('show');
    setTimeout(() => toast.classList.remove('show'), 3200);
    history.replaceState({}, '', '/chats');
  }
</script>

</body>
</html>
